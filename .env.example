# Server
PORT=3001
NODE_ENV=development

# Database — PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/numericode

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS & email links)
CLIENT_URL=http://localhost:5173

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# IMPORTANT: The EMAIL_FROM address MUST be verified in your SendGrid account.
# Unverified senders cause SPF/DKIM failures → emails go to spam or are rejected.
# Verify at: https://app.sendgrid.com/settings/sender_auth/senders
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@numericode.com
EMAIL_FROM_NAME=NumeriCode
CONTACT_EMAIL_TO=nwaforugochukwu21@gmail.com
